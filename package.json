{
	"name": "gamesdatabase-front",
	"private": true,
	"version": "1.3.2",
	"type": "module",
	"author": "David H. Afonso",
	"description": "A modern web application for managing and organizing your personal game collection",
	"homepage": "https://github.com/David-H-Afonso/GamesDatabase.Front",
	"repository": {
		"type": "git",
		"url": "https://github.com/David-H-Afonso/GamesDatabase.Front.git"
	},
	"license": "GPL-3.0",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"lint": "eslint .",
		"preview": "vite preview",
		"format": "prettier --write \"src/**/*.{ts,tsx,scss,css,json}\"",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:ui": "vitest --ui",
		"cypress:open": "cypress open",
		"cypress:run": "cypress run"
	},
	"dependencies": {
		"@reduxjs/toolkit": "^2.9.0",
		"formik": "^2.4.6",
		"react": "^19.1.1",
		"react-dom": "^19.1.1",
		"react-redux": "^9.2.0",
		"react-router-dom": "^7.8.2",
		"redux-persist": "^6.0.0",
		"vite-plugin-svgr": "^4.5.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.33.0",
		"@testing-library/cypress": "^10.1.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^24.6.2",
		"@types/react": "^19.1.10",
		"@types/react-dom": "^19.1.7",
		"@vitejs/plugin-react": "^5.0.0",
		"@vitest/coverage-v8": "^4.1.2",
		"cypress": "^15.13.0",
		"eslint": "^9.33.0",
		"eslint-plugin-react-hooks": "^5.2.0",
		"eslint-plugin-react-refresh": "^0.4.20",
		"eslint-plugin-sonarjs": "^4.0.2",
		"globals": "^16.3.0",
		"jsdom": "^29.0.1",
		"msw": "^2.12.14",
		"prettier": "^3.8.1",
		"sass-embedded": "^1.92.1",
		"typescript": "~5.8.3",
		"typescript-eslint": "^8.39.1",
		"vite": "^7.1.2",
		"vitest": "^4.1.2"
	}
}
